<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/fragment_max_width"
        android:layout_gravity="center_horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_egress_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/egress_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ProgressBar
            android:id="@+id/progress_egress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/text_egress_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/text_egress_empty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/egress_empty"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/text_egress_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/text_egress_error"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/nb_orange"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/text_egress_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_retry_egress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/zero_peers_btn_learn_why"
            android:textAllCaps="false"
            android:background="@drawable/btn_bg_orange"
            android:visibility="gone"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:foreground="@drawable/focus_highlight"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/text_egress_error"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_egress_groups"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/text_egress_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_clear_egress_selection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/egress_clear"
            android:textAllCaps="false"
            android:background="@drawable/btn_bg_transparent"
            android:textColor="@color/nb_orange"
            android:visibility="gone"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:foreground="@drawable/focus_highlight"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/recycler_view_egress_groups"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
