<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nb_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxWidth="400dp"
        android:layout_gravity="center_horizontal"
        android:paddingLeft="48dp"
        android:paddingRight="48dp"
        android:paddingTop="48dp"
        android:paddingBottom="48dp">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/notification_icon"
            android:contentDescription="@string/desc_logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/text_setup_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_desc"
            android:textColor="@color/nb_txt"
            android:textAlignment="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_scan_qr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_scan_qr"
            android:textAllCaps="false"
            android:background="@drawable/btn_bg_orange"
            android:layout_marginTop="32dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:foreground="@drawable/focus_highlight"
            app:layout_constraintTop_toBottomOf="@id/text_setup_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/divider_or"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_or"
            android:textColor="@color/nb_txt_light"
            android:textAlignment="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btn_scan_qr"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/text_input_setup_key"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/setup_key_hint"
            android:layout_marginTop="12dp"
            app:boxStrokeColor="@color/text_input_stroke"
            app:layout_constraintTop_toBottomOf="@id/divider_or"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_text_setup_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:imeOptions="actionDone"
                android:maxLines="1"
                android:textColor="@color/nb_txt" />

        </com.google.android.material.textfield.TextInputLayout>

        <ProgressBar
            android:id="@+id/progress_setup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/text_input_setup_key"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_connect"
            android:textAllCaps="false"
            android:background="@drawable/btn_bg_orange"
            android:layout_marginTop="16dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:foreground="@drawable/focus_highlight"
            app:layout_constraintTop_toBottomOf="@id/progress_setup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
